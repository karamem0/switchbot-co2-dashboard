{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Azure": "Error",
      "Microsoft": "Error",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information",
        "Azure": "Error",
        "Microsoft": "Error",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000",
    "EnableAdaptiveSampling": false,
    "EnableDependencyTrackingTelemetryModule": false,
    "EnablePerformanceCounterCollectionModule": false
  },
  "AzureStorageBlobs": {
    "Endpoint": "{{AZURE_STORAGE_BLOBS_ENDPOINT}}"
  },
  "MicrosoftIdentity": {
    "ClientId": "{{MICROSOFT_IDENTITY_APP_ID}}",
    "ClientSecret": "{{MICROSOFT_IDENTITY_APP_SECRET}}",
    "Instance": "https://login.microsoftonline.com",
    "TenantId": "{{MICROSOFT_IDENTITY_TENANT_ID}}"
  },
  "SwitchBot": {
    "Endpoint": "https://api.switch-bot.com/",
    "Token": "{{SWITCHBOT_TOKEN}}",
    "Secret": "{{SWITCHBOT_SECRET}}"
  }
}
